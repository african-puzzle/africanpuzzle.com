---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const team = [
  { name: 'Bams Betga', role: { fr: 'Fondateur & CEO', en: 'Founder & CEO', pcm: 'Founder & CEO' }, linkedin: 'https://linkedin.com/in/bams-betga' },
  { name: 'Benjamin Mbiandjeu', role: { fr: 'Co-Fondateur, Risques', en: 'Co-Founder, Risk', pcm: 'Co-Founder, Risk' }, linkedin: 'https://linkedin.com/in/benjamin-mbiandjeu' },
  { name: 'Jerome Ebella', role: { fr: 'Co-Fondateur, Directeur Commercial', en: 'Co-Founder, Business Manager', pcm: 'Co-Founder, Business Manager' }, linkedin: 'https://linkedin.com/in/jerome-ebella' },
  { name: 'Alain Titty Dimbeng', role: { fr: 'Co-Fondateur, Stratégie', en: 'Co-Founder, Strategy', pcm: 'Co-Founder, Strategy' }, linkedin: '' },
];
---

<section class="pt-32 pb-20 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-brand-purple-600 font-semibold text-sm uppercase tracking-wider">
        {t(lang, 'about.label')}
      </span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white">
        {t(lang, 'about.title')}
      </h1>
      <p class="mt-6 text-xl text-slate-600 dark:text-slate-300 leading-relaxed">
        {t(lang, 'about.subtitle')}
      </p>
    </div>

    <!-- Mission -->
    <div class="max-w-3xl mx-auto mb-20">
      <div class="bg-gradient-to-br from-brand-purple-50 to-blue-50 dark:from-brand-purple-900/20 dark:to-blue-900/20 rounded-2xl p-8 lg:p-12 border border-brand-purple-100 dark:border-brand-purple-800/30">
        <p class="text-lg text-slate-700 dark:text-slate-300 leading-relaxed">
          {t(lang, 'about.mission')}
        </p>
      </div>
    </div>

    <!-- Team -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white">
        {t(lang, 'about.team_title')}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {team.map((member) => (
        <div class="text-center group">
          <div class="w-24 h-24 mx-auto mb-4 rounded-full bg-gradient-to-br from-brand-purple-400 to-brand-blue-600 flex items-center justify-center text-white text-2xl font-bold shadow-lg group-hover:shadow-xl transition-shadow duration-300">
            {member.name.split(' ').map(n => n[0]).join('')}
          </div>
          <h3 class="font-bold text-slate-900 dark:text-white text-lg">
            {member.name}
          </h3>
          <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">
            {member.role[lang]}
          </p>
          {member.linkedin && (
            <a
              href={member.linkedin}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 mt-3 text-sm text-brand-purple-600 hover:text-brand-purple-700 transition-colors"
            >
              LinkedIn
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
