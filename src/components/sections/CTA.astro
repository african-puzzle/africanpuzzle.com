---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const PLAY_STORE = 'https://play.google.com/store/apps/details?id=com.africanpuzzle.africanpuzzleworks';
---

<section class="py-20 lg:py-28 bg-slate-50 dark:bg-slate-800/50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 dark:text-white">
      {t(lang, 'cta.title')}
    </h2>
    <p class="mt-4 text-lg text-slate-600 dark:text-slate-300 max-w-2xl mx-auto">
      {t(lang, 'cta.subtitle')}
    </p>
    <div class="mt-10">
      <a
        href={PLAY_STORE}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-5 bg-brand-purple-600 text-white text-lg font-semibold rounded-full shadow-lg shadow-brand-purple-600/25 hover:bg-brand-purple-700 hover:shadow-xl hover:shadow-brand-purple-600/30 transition-all duration-300 hover:-translate-y-0.5"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 010 1.732l-2.807 1.626L15.206 12l2.492-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
        </svg>
        {t(lang, 'cta.button')}
      </a>
    </div>
  </div>
</section>
