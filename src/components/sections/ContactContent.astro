---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const contacts = [
  { name: 'WhatsApp', href: 'https://api.whatsapp.com/send?phone=33176774727', value: '+33 17677 4727', icon: 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z' },
  { name: 'Email', href: 'mailto:contact@africanpuzzle.com', value: 'contact@africanpuzzle.com', icon: 'M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z', isStroke: true },
  { name: 'Telegram', href: 'https://t.me/africanpuzzle_bot', value: '@africanpuzzle_bot', icon: 'M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z' },
];

const socials = [
  { name: 'Facebook', href: 'https://facebook.com/AfricanPuzzle' },
  { name: 'Instagram', href: 'https://instagram.com/africanpuzzle' },
  { name: 'Twitter', href: 'https://twitter.com/african_puzzle' },
  { name: 'LinkedIn', href: 'https://linkedin.com/company/african-puzzle' },
  { name: 'YouTube', href: 'https://youtube.com/channel/UCcwmeCUwyZbX5xBUjxE57MA' },
];
---

<section class="pt-32 pb-20 lg:pb-28">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <span class="text-brand-purple-600 font-semibold text-sm uppercase tracking-wider">
        {t(lang, 'contact.label')}
      </span>
      <h1 class="mt-3 text-4xl sm:text-5xl font-bold text-slate-900 dark:text-white">
        {t(lang, 'contact.title')}
      </h1>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">
        {t(lang, 'contact.subtitle')}
      </p>
    </div>

    <div class="max-w-3xl mx-auto space-y-6">
      <!-- Direct contacts -->
      {contacts.map((contact) => (
        <a
          href={contact.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-5 p-6 bg-white dark:bg-slate-800 rounded-2xl border border-slate-100 dark:border-slate-700 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300"
        >
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-purple-50 dark:bg-brand-purple-900/30 flex items-center justify-center text-brand-purple-600">
            {contact.isStroke ? (
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d={contact.icon} />
              </svg>
            ) : (
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d={contact.icon} />
              </svg>
            )}
          </div>
          <div>
            <div class="font-semibold text-slate-900 dark:text-white">{contact.name}</div>
            <div class="text-sm text-slate-500 dark:text-slate-400">{contact.value}</div>
          </div>
        </a>
      ))}

      <!-- Address -->
      <div class="p-6 bg-white dark:bg-slate-800 rounded-2xl border border-slate-100 dark:border-slate-700">
        <div class="flex items-center gap-5">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-brand-purple-50 dark:bg-brand-purple-900/30 flex items-center justify-center text-brand-purple-600">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <div class="font-semibold text-slate-900 dark:text-white">{t(lang, 'contact.address_label')}</div>
            <div class="text-sm text-slate-500 dark:text-slate-400">{t(lang, 'contact.address')}</div>
          </div>
        </div>
      </div>

      <!-- Social links -->
      <div class="pt-8">
        <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-6 text-center">
          {t(lang, 'contact.social_label')}
        </h2>
        <div class="flex flex-wrap justify-center gap-4">
          {socials.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="px-6 py-3 bg-white dark:bg-slate-800 rounded-full border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 font-medium hover:border-brand-purple-300 hover:text-brand-purple-600 hover:shadow-md transition-all duration-300"
            >
              {social.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
