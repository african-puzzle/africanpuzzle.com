---
import { t, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const PLAY_STORE = 'https://play.google.com/store/apps/details?id=com.africanpuzzle.africanpuzzleworks';
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-purple-50 via-white to-blue-50 dark:from-slate-900 dark:via-slate-900 dark:to-brand-purple-900/20"></div>

  <!-- Decorative blobs -->
  <div class="absolute top-20 left-10 w-72 h-72 bg-brand-purple-200/30 rounded-full blur-3xl"></div>
  <div class="absolute bottom-20 right-10 w-96 h-96 bg-blue-200/20 rounded-full blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center px-4 py-2 rounded-full bg-brand-purple-100 dark:bg-brand-purple-900/30 text-brand-purple-700 dark:text-brand-purple-300 text-sm font-medium mb-8">
      <span class="w-2 h-2 bg-brand-purple-500 rounded-full mr-2 animate-pulse"></span>
      African Puzzle WORKS
    </div>

    <!-- Heading -->
    <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-white leading-tight max-w-4xl mx-auto">
      {t(lang, 'hero.title')}
    </h1>

    <!-- Subtitle -->
    <p class="mt-6 text-lg sm:text-xl text-slate-600 dark:text-slate-300 max-w-2xl mx-auto leading-relaxed">
      {t(lang, 'hero.subtitle')}
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={PLAY_STORE}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-8 py-4 bg-brand-purple-600 text-white font-semibold rounded-full shadow-lg shadow-brand-purple-600/25 hover:bg-brand-purple-700 hover:shadow-xl hover:shadow-brand-purple-600/30 transition-all duration-300 hover:-translate-y-0.5"
      >
        <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor">
          <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 01-.61-.92V2.734a1 1 0 01.609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.807 1.626a1 1 0 010 1.732l-2.807 1.626L15.206 12l2.492-2.492zM5.864 2.658L16.8 8.99l-2.302 2.302-8.634-8.634z"/>
        </svg>
        {t(lang, 'hero.cta')}
      </a>
      <a
        href="#fonctionnalites"
        class="inline-flex items-center gap-2 px-8 py-4 bg-white dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-semibold rounded-full border border-slate-200 dark:border-slate-700 hover:border-brand-purple-300 hover:text-brand-purple-600 shadow-sm hover:shadow-md transition-all duration-300"
      >
        {t(lang, 'hero.learn_more')}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

    <!-- Phone mockup placeholder -->
    <div class="mt-16 max-w-sm mx-auto">
      <div class="relative mx-auto w-64 h-[500px] bg-slate-900 rounded-[3rem] p-3 shadow-2xl">
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-slate-900 rounded-b-2xl"></div>
        <div class="w-full h-full bg-gradient-to-br from-brand-purple-600 to-brand-blue-600 rounded-[2.25rem] flex items-center justify-center">
          <div class="text-center text-white">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-80" viewBox="0 0 32 32" fill="none">
              <rect width="32" height="32" rx="8" fill="white" fill-opacity="0.2" />
              <path d="M8 16l4-8 4 8-4 8z" fill="white" opacity="0.9" />
              <path d="M16 16l4-8 4 8-4 8z" fill="white" opacity="0.6" />
            </svg>
            <p class="text-sm font-medium opacity-70">African Puzzle WORKS</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
